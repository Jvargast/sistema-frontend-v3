{
  "name": "testing",
  "private": true,
  "version": "2.5.3",
  "description": "Frontend del ERP AguasValentino",
  "author": "WOU",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "start": "electron .",
    "build": "cross-env NODE_ENV=production vite build && electron-builder",
    "build:web": "vite build --mode production",
    "build:android": "npm run build:web && npx cap sync android && npx cap open android",
    "build:electron": "vite build && electron-builder",
    "preview": "vite preview --mode production --port=3000",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages -d dist"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.8.0"
  },
  "dependencies": {
    "@capacitor/android": "8.3.1",
    "@capacitor/core": "8.3.1",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@hello-pangea/dnd": "18.0.1",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@mui/icons-material": "9.0.0",
    "@mui/material": "9.0.0",
    "@mui/x-charts": "9.0.3",
    "@mui/x-data-grid": "9.0.3",
    "@mui/x-date-pickers": "9.0.3",
    "@react-google-maps/api": "2.20.8",
    "@reduxjs/toolkit": "2.11.2",
    "date-fns": "4.1.0",
    "dayjs": "1.11.20",
    "dotenv": "17.4.2",
    "file-saver": "2.0.5",
    "framer-motion": "12.38.0",
    "i18next": "26.0.8",
    "js-cookie": "3.0.5",
    "leaflet": "1.9.4",
    "lodash.debounce": "4.0.8",
    "prop-types": "15.8.1",
    "react": "19.2.5",
    "react-calendar": "6.0.1",
    "react-countup": "6.5.3",
    "react-dom": "19.2.5",
    "react-dropzone": "15.0.0",
    "react-highlight-words": "0.21.0",
    "react-hook-form": "7.74.0",
    "react-i18next": "17.0.6",
    "react-is": "19.2.5",
    "react-leaflet": "5.0.0",
    "react-redux": "9.2.0",
    "react-router": "7.14.2",
    "react-router-dom": "7.14.2",
    "react-select": "5.10.2",
    "react-window": "2.2.7",
    "recharts": "3.8.1",
    "resize-observer-polyfill": "1.5.1",
    "socket.io-client": "4.8.3",
    "swapy": "1.0.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.1",
    "@eslint/js": "9.39.4",
    "@tailwindcss/vite": "4.2.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "cross-env": "10.1.0",
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "gh-pages": "6.3.0",
    "globals": "17.5.0",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  },
  "main": "electron.js",
  "build": {
    "appId": "com.wou.aguasvalentino",
    "productName": "ERP AguasValentino",
    "icon": "resources/icon.png",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.js"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
